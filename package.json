{
  "name": "anchor-assistant",
  "version": "1.2.0",
  "description": "",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/esm/index.js",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "postbuild": "echo '{\"type\": \"module\"}' > dist/esm/package.json",
    "build": "tsc --module es2022 --outDir dist/esm && npm run postbuild",
    "start": "tsc --module es2022 --outDir dist/esm --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/homoSanyok/anchor-assistant.git"
  },
  "author": "homoSanyok",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/homoSanyok/anchor-assistant/issues"
  },
  "homepage": "https://github.com/homoSanyok/anchor-assistant#readme",
  "devDependencies": {
    "@types/node": "^25.0.9",
    "typescript": "^5.9.2"
  },
  "files": [
    "dist/**",
    "README.md"
  ],
  "dependencies": {
    "openai": "^6.16.0"
  }
}
